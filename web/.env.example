# Set to "0" only on the public marketing/docs deploy (e.g. Vercel).
# When "0": /investigations and /config redirect to /repi/docs, and the
# "Open Investigations" CTA is hidden from the navbar.
# Any other value (or unset) leaves the app fully accessible — the default
# for local dev and the published docker image.
NEXT_PUBLIC_REPI_PUBLIC=
