# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lograg_user:password_here@127.0.0.1:5432/lograg

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=mistral                    # openai | anthropic | mistral | gemini | ollama
MISTRAL_API_KEY=your_mistral_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# OLLAMA_BASE_URL=http://localhost:11434

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
ENABLE_REDIS_CACHE=true
REDIS_CACHE_TTL_SECONDS=300
EMBEDDING_CACHE_TTL_SECONDS=3600

# ── Investigation ─────────────────────────────────────────────────────────────
TIME_WINDOW_INITIAL_MINUTES=10
TIME_WINDOW_EXPANSIONS=60,360,1440

# ── Web UI ────────────────────────────────────────────────────────────────────
UI_PORT=3000

# ── Runtime ───────────────────────────────────────────────────────────────────
# Default is production. Only set to "development" for local hacking — it
# enables verbose CLI/uvicorn logs and allows --reload.
REPI_ENV=production
